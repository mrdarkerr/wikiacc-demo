generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ProductType {
  CUSTOM_FORM
  INSTANT_DELIVERY
}

enum FieldType {
  TEXT
  EMAIL
  PHONE
  TEXTAREA
  SELECT
}

enum DeliveryItemStatus {
  AVAILABLE
  RESERVED
  DELIVERED
  DISABLED
}

enum OrderStatus {
  DRAFT
  PENDING_INFO
  AWAITING_ADMIN
  READY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum WalletTransactionType {
  ADMIN_CREDIT
  ADMIN_DEBIT
  ORDER_PAYMENT
  ORDER_REFUND
  GATEWAY_TOPUP
}

enum WalletTransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum TicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
}

model User {
  id                       String              @id @default(cuid())
  email                    String              @unique
  phone                    String?             @unique
  name                     String
  passwordHash             String
  role                     UserRole            @default(USER)
  wallet                   Wallet?
  orders                   Order[]
  tickets                  Ticket[]
  ticketMessages           TicketMessage[]
  walletTransactions       WalletTransaction[] @relation("WalletTransactionUser")
  adminWalletTransactions  WalletTransaction[] @relation("WalletTransactionAdmin")
  siteContentDraftUpdates  SiteContent[]       @relation("SiteContentDraftUpdater")
  siteContentPublications  SiteContent[]       @relation("SiteContentPublisher")
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
}

model ProductCategory {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String?
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id             String           @id @default(cuid())
  categoryId     String?
  category       ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  deliveryPoolId String?
  deliveryPool   DeliveryPool?    @relation(fields: [deliveryPoolId], references: [id], onDelete: SetNull)
  fields         ProductField[]
  features       ProductFeature[]
  orderItems     OrderItem[]
  slug           String           @unique
  title          String
  description    String?
  type           ProductType
  price          Int
  isActive       Boolean          @default(true)
  archivedAt     DateTime?
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([type, isActive, archivedAt, sortOrder])
}

model ProductFeature {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, sortOrder])
}

model ProductField {
  id          String            @id @default(cuid())
  productId   String
  product     Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  values      OrderFieldValue[]
  key         String
  label       String
  type        FieldType         @default(TEXT)
  required    Boolean           @default(false)
  optionsJson String?
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([productId, key])
}

model DeliveryPool {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String?
  items       DeliveryItem[]
  products    Product[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model DeliveryItem {
  id                     String             @id @default(cuid())
  poolId                 String
  pool                   DeliveryPool       @relation(fields: [poolId], references: [id], onDelete: Cascade)
  orderDeliveries        OrderDelivery[]
  content                String
  status                 DeliveryItemStatus @default(AVAILABLE)
  deliveredToOrderItemId String?
  deliveredAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  @@index([poolId, status, createdAt])
}

model Order {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items               OrderItem[]
  tickets             Ticket[]
  walletTransactionId String?
  status              OrderStatus      @default(DRAFT)
  paymentStatus       PaymentStatus    @default(UNPAID)
  totalAmount         Int
  note                String?
  adminNote           String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id                  String            @id @default(cuid())
  orderId             String
  order               Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product           @relation(fields: [productId], references: [id], onDelete: Restrict)
  fieldValues         OrderFieldValue[]
  deliveries          OrderDelivery[]
  titleSnapshot       String
  priceSnapshot       Int
  productTypeSnapshot ProductType
  quantity            Int               @default(1)
  createdAt           DateTime          @default(now())
}

model OrderFieldValue {
  id            String        @id @default(cuid())
  orderItemId   String
  orderItem     OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  fieldId       String?
  field         ProductField? @relation(fields: [fieldId], references: [id], onDelete: SetNull)
  keySnapshot   String
  labelSnapshot String
  value         String
  createdAt     DateTime      @default(now())

  @@unique([orderItemId, keySnapshot])
}

model OrderDelivery {
  id              String       @id @default(cuid())
  orderItemId     String
  orderItem       OrderItem    @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  deliveryItemId  String
  deliveryItem    DeliveryItem @relation(fields: [deliveryItemId], references: [id], onDelete: Restrict)
  contentSnapshot String
  deliveredAt     DateTime     @default(now())

  @@unique([deliveryItemId])
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WalletTransaction {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation("WalletTransactionUser", fields: [userId], references: [id], onDelete: Cascade)
  createdByAdminId String?
  createdByAdmin   User?                   @relation("WalletTransactionAdmin", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  amount           Int
  type             WalletTransactionType
  status           WalletTransactionStatus @default(COMPLETED)
  referenceType    String?
  referenceId      String?
  note             String?
  createdAt        DateTime                @default(now())

  @@index([userId, createdAt])
  @@index([referenceType, referenceId])
}

model Ticket {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  messages  TicketMessage[]
  subject   String
  status    TicketStatus    @default(OPEN)
  priority  TicketPriority  @default(NORMAL)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteContent {
  id               String   @id
  draftJson        String
  publishedJson    String
  draftVersion     Int      @default(1)
  publishedVersion Int      @default(1)
  draftUpdatedById String?
  draftUpdatedBy   User?    @relation("SiteContentDraftUpdater", fields: [draftUpdatedById], references: [id], onDelete: SetNull)
  publishedById    String?
  publishedBy      User?    @relation("SiteContentPublisher", fields: [publishedById], references: [id], onDelete: SetNull)
  draftUpdatedAt   DateTime @default(now())
  publishedAt      DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([draftUpdatedById])
  @@index([publishedById])
}

model SmsProviderSettings {
  id              String          @id
  provider        String          @unique
  apiKeyEncrypted String?
  apiKeyHint      String?
  defaultSenderId String?
  senders         SmsSenderLine[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model SmsSenderLine {
  id         String              @id @default(cuid())
  settingsId String
  settings   SmsProviderSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)
  label      String
  lineNumber String
  isActive   Boolean             @default(true)
  sortOrder  Int                 @default(0)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([settingsId, lineNumber])
  @@index([settingsId, isActive, sortOrder])
}
